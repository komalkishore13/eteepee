# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/youtube-clone?retryWrites=true&w=majority

# JWT secret key — use a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# App URL (used for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
